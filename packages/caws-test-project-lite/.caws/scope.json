{
  "version": 1,
  "allowedDirectories": ["src/", "tests/", "docs/"],
  "bannedPatterns": {
    "files": ["*-enhanced.*", "*-final.*", "*-v2.*", "*-copy.*"],
    "directories": ["*venv*", ".venv", "m-venv", "env/"],
    "docs": ["*-summary.md", "*-recap.md", "*-plan.md", "sprint-*"]
  },
  "maxNewFilesPerCommit": 10,
  "designatedVenvPath": ".venv"
}
