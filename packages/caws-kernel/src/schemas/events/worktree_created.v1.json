{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caws.paths.design/schemas/events/worktree_created.v1.json",
  "title": "worktree_created event payload",
  "$comment": "Class: OPTIONAL_SPEC_ID. spec_id present when the worktree is created already-bound.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "branch", "base_branch", "path"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "branch": {
      "type": "string",
      "minLength": 1,
      "description": "Typically caws/<name>"
    },
    "base_branch": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "description": "Absolute path to the linked worktree directory."
    },
    "owner_session_id": {
      "type": "string",
      "minLength": 1,
      "description": "The session id that created and now owns this worktree."
    }
  }
}
