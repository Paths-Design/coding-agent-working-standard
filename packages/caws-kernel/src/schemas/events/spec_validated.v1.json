{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caws.paths.design/schemas/events/spec_validated.v1.json",
  "title": "spec_validated event payload",
  "$comment": "Class: REQUIRES_SPEC_ID. Records a single validation pass.",
  "type": "object",
  "additionalProperties": false,
  "required": ["passed", "error_count", "warning_count"],
  "properties": {
    "passed": { "type": "boolean" },
    "error_count": { "type": "integer", "minimum": 0 },
    "warning_count": { "type": "integer", "minimum": 0 },
    "compliance_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "grade": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "F"]
    },
    "rules_violated": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Stable rule identifiers from the Diagnostic.rule field. Used for trend analysis."
    }
  }
}
