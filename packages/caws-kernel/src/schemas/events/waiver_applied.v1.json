{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caws.paths.design/schemas/events/waiver_applied.v1.json",
  "title": "waiver_applied event payload",
  "$comment": "Class: REQUIRES_SPEC_ID. Records a waiver expanding budget or covering a gate failure. Waivers are strictly additive; delta >= 0.",
  "type": "object",
  "additionalProperties": false,
  "required": ["waiver_id", "gates"],
  "properties": {
    "waiver_id": {
      "type": "string",
      "pattern": "^WV-\\d{4}$",
      "description": "Waiver identifier. 4-digit zero-padded format."
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "budget_limit",
          "spec_completeness",
          "scope_boundary",
          "god_object",
          "todo_detection"
        ]
      },
      "description": "Gates this waiver covers. A waiver only expands budget if 'budget_limit' is in this list."
    },
    "delta": {
      "type": "object",
      "description": "Budget expansion (when waiver covers budget_limit). All values must be >= 0; waivers are strictly additive.",
      "additionalProperties": false,
      "properties": {
        "max_files": { "type": "integer", "minimum": 0 },
        "max_loc": { "type": "integer", "minimum": 0 }
      }
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "approvers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "role": { "type": "string" }
        }
      }
    },
    "reason_code": {
      "type": "string",
      "minLength": 1
    }
  }
}
