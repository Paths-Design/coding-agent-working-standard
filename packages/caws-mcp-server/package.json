{
  "name": "@paths.design/caws-mcp-server",
  "version": "1.1.3",
  "description": "CAWS Model Context Protocol server for AI agent integration",
  "type": "module",
  "main": "index.js",
  "bin": {
    "caws-mcp-server": "./index.js"
  },
  "scripts": {
    "build": "echo 'MCP Server does not require building'",
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "npx eslint index.js src/",
    "typecheck": "echo 'MCP Server type checking not configured (ES modules)'",
    "format": "prettier --write index.js src/",
    "prepare": "husky"
  },
  "keywords": [
    "caws",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "quality-assurance"
  ],
  "author": "@darianrosebrook",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.2",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "husky": "9.1.7",
    "jest": "^30.1.3"
  },
  "jest": {
    "transform": {},
    "testMatch": ["<rootDir>/tests/**/*.test.js"]
  },
  "peerDependencies": {
    "@paths.design/caws-cli": "*",
    "@paths.design/quality-gates": "*"
  },
  "peerDependenciesMeta": {
    "@paths.design/caws-cli": {
      "optional": false
    },
    "@paths.design/quality-gates": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paths-design/caws.git",
    "directory": "packages/caws-mcp-server"
  },
  "bugs": {
    "url": "https://github.com/paths-design/caws/issues"
  },
  "homepage": "https://github.com/paths-design/caws#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
