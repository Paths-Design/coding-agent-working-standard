{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "caws.events.v1.evaluation_completed",
  "title": "evaluation_completed event data",
  "description": "Emitted by evaluate.js after recordEvaluation. Spec-scoped.",
  "type": "object",
  "required": ["score", "max_score", "percentage", "grade", "checks_passed", "checks_total"],
  "properties": {
    "score": { "type": "number", "minimum": 0 },
    "max_score": { "type": "number", "minimum": 0 },
    "percentage": { "type": "number", "minimum": 0, "maximum": 100 },
    "grade": { "type": "string", "enum": ["A", "B", "C", "D", "F"] },
    "checks_passed": { "type": "integer", "minimum": 0 },
    "checks_total": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
