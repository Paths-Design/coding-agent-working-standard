{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "caws.events.v1.validation_completed",
  "title": "validation_completed event data",
  "description": "Emitted by validate.js after recordValidation. Spec-scoped — spec_id is required at the envelope level.",
  "type": "object",
  "required": ["passed", "error_count", "warning_count"],
  "properties": {
    "passed": { "type": "boolean" },
    "compliance_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100
    },
    "grade": {
      "type": ["string", "null"],
      "enum": ["A", "B", "C", "D", "F", null]
    },
    "error_count": { "type": "integer", "minimum": 0 },
    "warning_count": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
