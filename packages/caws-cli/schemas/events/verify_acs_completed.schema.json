{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "caws.events.v1.verify_acs_completed",
  "title": "verify_acs_completed event data",
  "description": "Emitted by verify-acs.js after recordACVerification. Spec-scoped.",
  "type": "object",
  "required": ["total", "pass", "fail", "unchecked"],
  "properties": {
    "total": { "type": "integer", "minimum": 0 },
    "pass": { "type": "integer", "minimum": 0 },
    "fail": { "type": "integer", "minimum": 0 },
    "unchecked": { "type": "integer", "minimum": 0 },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "UNCHECKED"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
