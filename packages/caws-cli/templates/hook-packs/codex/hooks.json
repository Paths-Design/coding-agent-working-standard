{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "__CAWS_CODEX_SESSION_START_COMMAND__",
            "timeout": 30,
            "statusMessage": "Registering CAWS session"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "__CAWS_CODEX_PRE_TOOL_USE_COMMAND__",
            "timeout": 45,
            "statusMessage": "Checking CAWS guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "__CAWS_CODEX_POST_TOOL_USE_COMMAND__",
            "timeout": 60,
            "statusMessage": "Recording CAWS hook evidence"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "__CAWS_CODEX_PRE_COMPACT_COMMAND__",
            "timeout": 30,
            "statusMessage": "Preparing CAWS compact context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CAWS_CODEX_STOP_COMMAND__",
            "timeout": 30,
            "statusMessage": "Stopping CAWS session"
          }
        ]
      }
    ]
  }
}
