{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CAWS CLI",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/packages/caws-cli/src/index.js",
      "args": ["validate", "--spec-id", "${input:specId}"],
      "env": {
        "NODE_ENV": "development",
        "CAWS_DEBUG": "true"
      },
      "console": "integratedTerminal"
    }
  ]
}
