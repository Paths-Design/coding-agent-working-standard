id: EVLOG-001
type: feature
title: Event log dual-write (Phase 1)
status: active
risk_tier: 3
mode: development
created_at: '2026-04-10T19:04:40.489Z'
updated_at: '2026-04-10T19:04:40.489Z'
blast_radius:
  modules:
    - packages/caws-cli/src/utils/event-log
    - packages/caws-cli/src/utils/event-renderer
    - packages/caws-cli/schemas/events
  data_migration: false
operational_rollback_slo: 5m
scope:
  in:
    - packages/caws-cli/src/utils/event-log.js
    - packages/caws-cli/src/utils/event-renderer.js
    - packages/caws-cli/src/commands/validate.js
    - packages/caws-cli/src/commands/evaluate.js
    - packages/caws-cli/src/commands/verify-acs.js
    - packages/caws-cli/src/commands/gates.js
    - packages/caws-cli/src/commands/specs.js
    - packages/caws-cli/src/session/session-manager.js
    - packages/caws-cli/schemas/events/
    - packages/caws-cli/tests/event-log.test.js
    - packages/caws-cli/tests/event-renderer.test.js
    - packages/caws-cli/tests/integration/event-log-parity.test.js
    - docs/internal/EVENTS_LOG_MIGRATION.md
    - .caws/specs/EVLOG-001.yaml
    - .gitignore
  out:
    - node_modules/
    - dist/
    - packages/caws-cli/dist/
    - packages/caws-cli/src/utils/working-state.js
invariants:
  - State layer continues to work unchanged during Phase 1 (dual-write, not cut-over)
  - Event log is append-only; no in-place edits after a record is committed
  - Events missing a required spec_id fail loudly — no silent writes
  - renderSpecState is a pure function with no filesystem or side effects
  - Hash chain is contiguous from genesis to tail
acceptance:
  - id: A1
    given: A fresh project with no .caws/events.jsonl
    when: validate is run against a fixture spec
    then: >-
      .caws/events.jsonl is created with a single validation_completed event at seq=1 with empty prev_hash and a
      computed event_hash
  - id: A2
    given: An existing .caws/events.jsonl with N events
    when: A new event is appended
    then: The new event has seq=N+1 and prev_hash equal to the last event event_hash
  - id: A3
    given: A spec that has been validated evaluated and gated
    when: renderSpecState events and spec id is called
    then: >-
      The returned view is equivalent to loadState on the fields iterate consumes phase validation evaluation gates
      acceptance_criteria blockers next_actions files_touched
  - id: A4
    given: A call to appendEvent with an event type that requires spec_id
    when: spec_id is undefined or null or empty string
    then: appendEvent throws a loud error naming the event type and the violated contract and no file write occurs
  - id: A5
    given: A spec that has been closed via specs close
    when: The event log is rendered
    then: A spec_closed event is present with the prior status and renderSpecState returns phase closed for that spec
  - id: A6
    given: A session has started and ended
    when: The event log is rendered
    then: >-
      session_started and session_ended events exist with matching session id and session_ended data includes the final
      files_touched list
  - id: A7
    given: The full jest suite before and after this change
    when: The suite is run
    then: No pre-existing test regresses and state layer behavior is unchanged
non_functional:
  perf:
    api_p95_ms: 50
  a11y: []
  security:
    - >-
      Event log contains spec IDs and file paths but no secrets. Existing gitignore pattern for .caws/state/ is extended
      to .caws/events.jsonl.
contracts: []
worktree: evlog-001
