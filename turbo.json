{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", ".caws/**", "!**/*.test.*"],
      "outputs": ["dist/**", "build/**", ".agent/**"]
    },
    "lint": {
      "dependsOn": [],
      "inputs": ["src/**", ".caws/**", "*.js", "*.json"]
    },
    "lint:fix": {
      "dependsOn": [],
      "inputs": ["src/**", ".caws/**", "*.js", "*.json"]
    },
    "format": {
      "dependsOn": [],
      "inputs": ["src/**", ".caws/**", "*.js", "*.json", "*.md"]
    },
    "test": {
      "dependsOn": ["^build", "lint"],
      "inputs": ["src/**", "tests/**", ".caws/**"],
      "outputs": ["coverage/**"]
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tests/**"],
      "outputs": []
    },
    "test:watch": {
      "dependsOn": [],
      "persistent": true,
      "cache": false
    },
    "validate": {
      "dependsOn": [],
      "inputs": [".caws/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tests/**", "*.ts", "*.tsx", "tsconfig*.json"]
    },
    "clean": {
      "dependsOn": [],
      "cache": false
    },
    "dev": {
      "dependsOn": ["build"],
      "persistent": true,
      "cache": false
    }
  },
  "globalDependencies": [
    "package.json",
    "turbo.json",
    "eslint.config.js",
    ".prettierrc"
  ]
}
