{
  "name": "caws",
  "version": "11.5.0",
  "description": "CAWS - Coding Agent Working Standard (Turborepo)",
  "website": "https://paths.design",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "// Core turbo scripts (delegated to individual packages)": "",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:staged": "lint-staged",
    "format": "turbo run format",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:unit": "turbo run test",
    "test:fast": "./scripts/test-runner.sh --mode fast",
    "test:runner": "./scripts/test-runner.sh",
    "validate": "turbo run validate",
    "typecheck": "turbo run typecheck --continue",
    "clean": "turbo run clean",
    "build:main-dist-link": "node scripts/build-main-dist-link.mjs",

    "// CAWS CLI shortcuts (improved to actually run commands)": "",
    "cli": "node packages/caws-cli/dist/index.js --help",
    "scaffold": "node packages/caws-cli/dist/index.js scaffold",
    "init": "node packages/caws-cli/dist/index.js init",

    "// Development utilities": "",
    "hooks:install": "chmod +x .git/hooks/pre-commit .git/hooks/pre-push",
    "release": "semantic-release",

    "// CAWS-specific tools": "",
    "caws:validate": "caws doctor",
    "caws:verify": "exec bash scripts/verify.sh",

    "// Code modification tools": "",
    "codemod:dry": "node docs/*/codemod/refactor.js",
    "codemod:apply": "node docs/*/codemod/refactor.js --apply"
  },
  "keywords": ["caws", "cli", "scaffolding", "agents", "workflow", "turborepo", "monorepo"],
  "author": "Paths Design <hello@paths.design>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Paths-Design/coding-agent-working-standard.git"
  },
  "packageManager": "npm@10.0.0",
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.1",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-node": "^11.1.0",
    "lint-staged": "^15.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.22",
    "lodash-es": "^4.17.22",
    "qs": "^6.14.1",
    "body-parser": "^2.2.1"
  }
}
